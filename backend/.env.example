# Copy to .env (or export) before running. All have sensible defaults.

# Quote provider: mock (offline, deterministic §5) | finmind (real delayed quotes)
QUOTE_PROVIDER=mock
# FINMIND_TOKEN=your_finmind_token_here

# Quote older than this many minutes is marked stale=true (FR-10)
QUOTE_STALE_MINUTES=20

# Database
DATABASE_URL=sqlite:///./app.db

# Auth
JWT_SECRET=poc-dev-secret-change-me
JWT_EXPIRE_MINUTES=720

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173
